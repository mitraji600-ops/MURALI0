rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Entity Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'username', 'status', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 6
        && data.uid == request.auth.uid
        && data.email is string
        && data.username is string && data.username.size() <= 30 && data.username.size() >= 3
        && data.status in ['active', 'suspended', 'banned']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['displayName', 'creatorStatus', 'verificationStatus', 'followerCount', 'followingCount'])
        && data.displayName is string && data.displayName.size() <= 50
        && data.creatorStatus is bool
        && data.verificationStatus is bool
        && data.followerCount is number
        && data.followingCount is number;
    }

    // Users Collection (Strict PII Isolation)
    match /users/{userId} {
      // Users can read their own identity record
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // No list queries allowed for identity records
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && isOwner(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(userId)
        && isOwner(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
    }

    // Profiles Collection (Publicly readable, owner modifiable)
    match /profiles/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn()
        && isValidId(userId)
        && isOwner(userId)
        && isValidProfile(incoming());
        
      allow update: if isSignedIn()
        && isValidId(userId)
        && isOwner(userId)
        && isValidProfile(incoming());
    }
  }
}
